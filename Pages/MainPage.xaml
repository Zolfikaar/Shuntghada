<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Shuntghada.Models"
             x:Class="Shuntghada.Pages.MainPage"
             x:Name="OverviewPage"
             BackgroundColor="#F7F7F7">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

            <Label Text="شنتغده اليوم؟ 🍽️"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#E64A19"/>

            <Label Text="اضغط على الزر واكتشف مقترح غداء اليوم بدون حيرة!"
                   FontSize="16"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="#555555"/>

            <Button Text="اقترح إلنه طبخة!"
                    Clicked="OnSuggestButtonClicked"
                    BackgroundColor="#E64A19"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="60"
                    HorizontalOptions="Fill" />

            <BoxView HeightRequest="1" Color="#DDDDDD" HorizontalOptions="Fill" Margin="0,10"/>

            <VerticalStackLayout x:Name="SuggestionCard" 
                     IsVisible="True" 
                     Opacity="0" 
                     Spacing="15" 
                     HorizontalOptions="Fill">

                <Image x:Name="MealImage" 
                       HeightRequest="200" 
                       WidthRequest="300"
                       MinimumHeightRequest="200"
                       MinimumWidthRequest="300"
                       Aspect="AspectFill" 
                       HorizontalOptions="Center"
                       Source="dotnet_bot.png"/>

                <Label x:Name="MealNameLabel" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#333333"/>
                <Label x:Name="MealAltNameLabel" FontSize="16" FontAttributes="Italic" HorizontalOptions="Center" TextColor="#777777" HorizontalTextAlignment="Center"/>

                <Border BackgroundColor="#FFE0B2" StrokeShape="RoundRectangle 10" Padding="10,5" HorizontalOptions="Center">
                    <Label x:Name="DifficultyLabel" FontSize="14" TextColor="#E65100" FontAttributes="Bold"/>
                </Border>

                <Label x:Name="DescriptionLabel" FontSize="16" TextColor="#444444" HorizontalTextAlignment="Center" LineHeight="1.4"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10">
                    <Button Grid.Column="0" Text="طريقة العمل 📖" Clicked="OnViewRecipeClicked" BackgroundColor="#0288D1" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="50"/>
                    <Button Grid.Column="1" x:Name="AcceptButton" Text="صادقنا عليها ✔️" Clicked="OnAcceptButtonClicked" BackgroundColor="#388E3C" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="50"/>
                </Grid>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
