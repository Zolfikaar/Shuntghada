<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Shuntghada.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Shuntghada.Pages"
    Title="Shuntghada"
    FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <VerticalStackLayout Padding="20" BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#212121}">
            <Label Text="UrLabs 🧪" FontSize="14" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="شنتغده؟" FontSize="22" FontAttributes="Bold" Margin="0,5,0,0" />
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="الرئيسية" Icon="home_icon.png">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate pages:MainPage}"
            Route="main" />
    </FlyoutItem>

    <FlyoutItem Title="إقترح طبخة" Icon="suggest_icon.png">
        <ShellContent Title="إقترح طبخة"
                      ContentTemplate="{DataTemplate pages:SuggestMealPage}"
                      Route="SuggestMealPage" />
    </FlyoutItem>

    <Shell.FlyoutFooter>
        <VerticalStackLayout Padding="10">
            <Button Text="⚙️ إعدادات التطبيق"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    HorizontalOptions="Fill"
                    FontAttributes="Bold"
                    Clicked="OnSettingsFlyoutClicked" />
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

</Shell>
